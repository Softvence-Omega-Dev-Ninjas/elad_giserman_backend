model TermsAndConditions {
  id        String         @id @default(uuid())
  sections  TermsSection[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model TermsSection {
  id       String   @id @default(uuid())
  title    String
  content  String[]
  order    Int
  termsId  String
  terms    TermsAndConditions @relation(fields: [termsId], references: [id], onDelete: Cascade)
}

model UserTermsAndConditions {
  id                      String   @id @default(uuid())
  liability               String
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  arrvalAndSeatingPolicy  String[]
  canceletionAndNoShows   String[]
  conductAndBehaviour     String[]
  generalAgrement         String?
  modifications           String[]
  policyUpdate            String?
  reservationConfirmation String[]
  businessProfileId       String?
  businessProfile         User?    @relation(fields: [businessProfileId], references: [id])
}
